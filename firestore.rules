rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return userExists() && getUserData().role == "admin";
    }
    function isSupervisor() {
      return userExists() && getUserData().role == "supervisor";
    }
    function isAgent() {
      return userExists() && getUserData().role == "agent";
    }
    function sameTeam(resourceTeamId) {
      return userExists() && getUserData().team_id == resourceTeamId;
    }

    match /users/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isAdmin() || isSupervisor());
      allow write: if request.auth != null
                   && (request.auth.uid == uid || isAdmin());
    }

    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    match /clients/{clientId} {
      allow read: if request.auth != null
                  && (isAdmin()
                      || resource.data.owner_uid == request.auth.uid
                      || (isSupervisor() && sameTeam(resource.data.team_id)));
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (isAdmin()
                        || resource.data.owner_uid == request.auth.uid
                        || (isSupervisor() && sameTeam(resource.data.team_id)));
      allow delete: if request.auth != null
                    && (isAdmin()
                        || resource.data.owner_uid == request.auth.uid);
    }

    match /calls/{callId} {
      allow read: if request.auth != null
                  && (isAdmin()
                      || resource.data.owner_uid == request.auth.uid
                      || (isSupervisor() && sameTeam(resource.data.team_id)));
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (isAdmin()
                        || resource.data.owner_uid == request.auth.uid
                        || (isSupervisor() && sameTeam(resource.data.team_id)));
      allow delete: if request.auth != null
                    && (isAdmin()
                        || resource.data.owner_uid == request.auth.uid);
    }

    match /states/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    match /trades/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    match /glossary/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
  }
}
