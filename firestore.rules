rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getMember(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data;
    }

    function isWorkspaceMember(workspaceId) {
      return exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function memberRole(workspaceId) {
      return getMember(workspaceId).role;
    }

    match /users/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    match /workspaces/{workspaceId} {
      allow read: if request.auth != null
                  && isWorkspaceMember(workspaceId);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && memberRole(workspaceId) == "owner";
    }

    match /workspaces/{workspaceId}/members/{uid} {
      allow read: if request.auth != null
                  && isWorkspaceMember(workspaceId);
      allow write: if request.auth != null
                   && (memberRole(workspaceId) == "owner"
                       || request.auth.uid == uid);
    }

    match /workspaces/{workspaceId}/clients/{clientId} {
      allow read: if request.auth != null
                  && isWorkspaceMember(workspaceId)
                  && (memberRole(workspaceId) == "owner"
                      || (memberRole(workspaceId) == "supervisor"
                          && resource.data.subteam_id == getMember(workspaceId).subteam_id)
                      || resource.data.owner_uid == request.auth.uid);
      allow create: if request.auth != null
                    && isWorkspaceMember(workspaceId);
      allow update: if request.auth != null
                    && isWorkspaceMember(workspaceId)
                    && (memberRole(workspaceId) == "owner"
                        || (memberRole(workspaceId) == "supervisor"
                            && resource.data.subteam_id == getMember(workspaceId).subteam_id)
                        || resource.data.owner_uid == request.auth.uid);
      allow delete: if request.auth != null
                    && (memberRole(workspaceId) == "owner"
                        || resource.data.owner_uid == request.auth.uid);

      match /documents/{docId} {
        allow read: if request.auth != null
                    && isWorkspaceMember(workspaceId);
        allow create: if request.auth != null
                      && isWorkspaceMember(workspaceId);
        allow delete: if request.auth != null
                      && (memberRole(workspaceId) == "owner"
                          || resource.data.uploaded_by_uid == request.auth.uid);
      }
    }

    match /workspaces/{workspaceId}/calls/{callId} {
      allow read, write: if request.auth != null
                         && isWorkspaceMember(workspaceId);
    }

    match /workspaces/{workspaceId}/goals/{goalId} {
      allow read: if request.auth != null
                  && isWorkspaceMember(workspaceId);
      allow write: if request.auth != null
                   && isWorkspaceMember(workspaceId)
                   && (memberRole(workspaceId) == "owner"
                       || memberRole(workspaceId) == "supervisor");
    }

    match /workspaces/{workspaceId}/subteams/{subteamId} {
      allow read: if request.auth != null
                  && isWorkspaceMember(workspaceId);
      allow write: if request.auth != null
                   && memberRole(workspaceId) == "owner";
    }

    match /workspaces/{workspaceId}/invitations/{invId} {
      allow read: if request.auth != null
                  && isWorkspaceMember(workspaceId);
      allow create: if request.auth != null
                    && memberRole(workspaceId) == "owner";
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && memberRole(workspaceId) == "owner";
    }

    match /states/{doc} { allow read: if request.auth != null; }
    match /trades/{doc} { allow read: if request.auth != null; }
    match /glossary/{doc} { allow read: if request.auth != null; }
  }
}
