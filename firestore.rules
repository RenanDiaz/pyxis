rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return userExists() && getUserData().role == "admin";
    }
    function isTeamAdmin(teamId) {
      return teamId != null
        && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == "admin";
    }
    function isTeamMember(teamId) {
      return teamId != null
        && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == uid || isAdmin());
    }

    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (isAdmin() || isTeamAdmin(teamId));
      allow delete: if request.auth != null && isAdmin();

      match /members/{uid} {
        allow read: if request.auth != null && isTeamMember(teamId);
        allow create: if request.auth != null
                      && (isAdmin() || isTeamAdmin(teamId) || request.auth.uid == uid);
        allow update: if request.auth != null
                      && (isAdmin() || isTeamAdmin(teamId));
        allow delete: if request.auth != null
                      && (isAdmin()
                          || isTeamAdmin(teamId)
                          || request.auth.uid == uid);
      }
    }

    match /clients/{clientId} {
      allow read: if request.auth != null
                  && (isAdmin()
                      || resource.data.owner_uid == request.auth.uid
                      || isTeamAdmin(resource.data.team_id));
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (isAdmin()
                        || resource.data.owner_uid == request.auth.uid
                        || isTeamAdmin(resource.data.team_id));
      allow delete: if request.auth != null
                    && (isAdmin()
                        || resource.data.owner_uid == request.auth.uid);

      match /documents/{docId} {
        allow read: if request.auth != null
                    && (isAdmin()
                        || get(/databases/$(database)/documents/clients/$(clientId)).data.owner_uid == request.auth.uid
                        || isTeamAdmin(get(/databases/$(database)/documents/clients/$(clientId)).data.team_id));
        allow create: if request.auth != null
                      && (isAdmin()
                          || get(/databases/$(database)/documents/clients/$(clientId)).data.owner_uid == request.auth.uid
                          || isTeamAdmin(get(/databases/$(database)/documents/clients/$(clientId)).data.team_id));
        allow delete: if request.auth != null
                      && (isAdmin()
                          || get(/databases/$(database)/documents/clients/$(clientId)).data.owner_uid == request.auth.uid);
      }
    }

    match /calls/{callId} {
      allow read: if request.auth != null
                  && (isAdmin()
                      || resource.data.owner_uid == request.auth.uid
                      || isTeamAdmin(resource.data.team_id));
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (isAdmin()
                        || resource.data.owner_uid == request.auth.uid
                        || isTeamAdmin(resource.data.team_id));
      allow delete: if request.auth != null
                    && (isAdmin()
                        || resource.data.owner_uid == request.auth.uid);
    }

    match /team_invitations/{invId} {
      allow read: if request.auth != null
                  && (isAdmin()
                      || resource.data.email == request.auth.token.email.lower()
                      || isTeamAdmin(resource.data.team_id)
                      || isTeamMember(resource.data.team_id));
      allow create: if request.auth != null
                    && (isAdmin()
                        || isTeamAdmin(request.resource.data.team_id));
      allow update: if request.auth != null
                    && (isAdmin()
                        || isTeamAdmin(resource.data.team_id)
                        || resource.data.email == request.auth.token.email.lower());
      allow delete: if request.auth != null
                    && (isAdmin()
                        || isTeamAdmin(resource.data.team_id));
    }

    match /goals/{goalId} {
      allow read: if request.auth != null
                  && (isAdmin()
                      || resource.data.target_uid == request.auth.uid
                      || resource.data.set_by_uid == request.auth.uid
                      || isTeamAdmin(resource.data.team_id));
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (isAdmin()
                        || resource.data.set_by_uid == request.auth.uid
                        || isTeamAdmin(resource.data.team_id));
      allow delete: if request.auth != null
                    && (isAdmin()
                        || resource.data.set_by_uid == request.auth.uid);
    }

    match /states/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    match /trades/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    match /glossary/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
  }
}
