rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Workspace-scoped client files
    match /workspaces/{workspaceId}/clients/{clientId}/{allPaths=**} {
      allow read: if request.auth != null
                  && firestore.exists(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
      allow write: if request.auth != null
                   && firestore.exists(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
      allow delete: if request.auth != null
                    && firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role == "owner";
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
